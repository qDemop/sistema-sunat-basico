{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=erp_sunat;Username=placeholder;Password=placeholder"
  },
  "Jwt": {
    "Issuer": "ERP.API",
    "Audience": "ERP.WinForms",
    "Key": "CHANGE_ME_PLACEHOLDER_KEY_AT_LEAST_32_CHARS_LONG_",
    "ExpirationMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "File", "Args": { "path": "logs/erp-.log", "rollingInterval": "Day" } }
    ]
  },
  "AllowedHosts": "*"
}
